rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function ownerEmails() {
      return [
        "skillfulsweing@gmail.com",
        "sales@funandjoy.io"
      ];
    }

    function approvedUserEmails() {
      return [
        "skillfulsweing@gmail.com",
        "snek.sova@gmail.com",
        "sales@funandjoy.io"
      ];
    }

    function approvedEmail() {
      return signedIn() && request.auth.token.email in approvedUserEmails();
    }

    function isActive() {
      return approvedEmail() && userProfile().disabled != true;
    }

    function isOwner() {
      return isActive() && userProfile().role == "owner" && request.auth.token.email in ownerEmails();
    }

    function ownsExisting() {
      return isActive() && resource.data.ownerId == request.auth.uid;
    }

    function ownsIncoming() {
      return isActive() && request.resource.data.ownerId == request.auth.uid;
    }

    match /users/{userId} {
      allow create: if approvedEmail()
        && userId == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.disabled == false
        && (
          (request.auth.token.email in ownerEmails() && request.resource.data.role == "owner")
          || (!(request.auth.token.email in ownerEmails()) && request.resource.data.role == "sales_manager")
        );
      allow read: if approvedEmail() && (userId == request.auth.uid || isOwner());
      allow update: if isOwner();
      allow delete: if isOwner();
    }

    match /leads/{leadId} {
      allow create: if isOwner() || ownsIncoming();
      allow read: if isOwner() || ownsExisting();
      allow update: if isOwner() || (ownsExisting() && ownsIncoming());
      allow delete: if isOwner() || ownsExisting();
    }

    match /followUps/{followUpId} {
      allow create: if isOwner() || ownsIncoming();
      allow read: if isOwner() || ownsExisting();
      allow update: if isOwner() || (ownsExisting() && ownsIncoming());
      allow delete: if isOwner() || ownsExisting();
    }

    match /dailyReports/{reportId} {
      allow create: if isOwner() || ownsIncoming();
      allow update: if isOwner() || (ownsExisting() && ownsIncoming());
      allow read: if isOwner() || ownsExisting();
      allow delete: if isOwner() || ownsExisting();
    }

    match /dailyChecklists/{checklistId} {
      allow create: if isOwner() || ownsIncoming();
      allow update: if isOwner() || (ownsExisting() && ownsIncoming());
      allow read: if isOwner() || ownsExisting();
      allow delete: if isOwner() || ownsExisting();
    }
  }
}
